<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Header Panel -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true">

                <TextView
                    android:id="@+id/app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_addiction_destroyer"
                    android:textColor="@color/accent_red"
                    android:textSize="14sp"
                    android:textStyle="normal"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_settings_quick"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:text="🛡"
                android:textSize="24sp"
                android:gravity="center"
                android:background="@drawable/bg_circle_icon" />
        </RelativeLayout>

        <!-- Dynamic Segment Navigation Tab Layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout_segments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/accent_red"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/white"
            app:tabBackground="@color/black"
            app:tabIndicatorHeight="3dp">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shield" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stats" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Switches" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Segment 1: Shield Configuration Active Screen -->
        <LinearLayout
            android:id="@+id/container_tab_shield"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

        <!-- Status Card with Pulse Shadow -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/FocusCardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/status_icon_badge"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🔒"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_square_icon"
                        android:backgroundTint="@color/accent_red_glow"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/txt_shield_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_shield_inactive"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_toEndOf="@id/status_icon_badge"
                        android:layout_marginStart="14dp"
                        android:layout_alignTop="@id/status_icon_badge" />

                    <TextView
                        android:id="@+id/txt_shield_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accessibility service is offline"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_toEndOf="@id/status_icon_badge"
                        android:layout_marginStart="14dp"
                        android:layout_below="@id/txt_shield_title"
                        android:layout_marginTop="2dp" />
                </RelativeLayout>

                <Button
                    android:id="@+id/btn_toggle_accessibility"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Enable Accessibility Shield"
                    style="@style/FocusButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pomodoro Card (Moved to Shield Tab) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/FocusCardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/timer_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="⏱"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_square_icon"
                        android:backgroundTint="@color/accent_green_glow"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pomodoro Study Timer"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_toEndOf="@id/timer_icon"
                        android:layout_marginStart="12dp"
                        android:layout_alignTop="@id/timer_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock shorts/reels during sessions"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_toEndOf="@id/timer_icon"
                        android:layout_marginStart="12dp"
                        android:layout_below="@+id/timer_icon"
                        android:layout_marginTop="-16dp" />
                </RelativeLayout>

                <Button
                    android:id="@+id/btn_launch_timer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Open Focus Timer"
                    android:backgroundTint="@color/accent_green"
                    style="@style/FocusButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Segment 2: Statistics & Live Screen Diagnostics -->
        <LinearLayout
            android:id="@+id/container_tab_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <!-- Usage Access Perm Warning Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_usage_permission_warn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/FocusCardView"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ SCREEN TIME MONITOR OFFLINE"
                    android:textColor="@color/accent_orange"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Give FocusVault Screen Usage permission to monitor real-time distraction hours for accurate analytical profiling."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_grant_usage_stats"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Grant Usage Permission"
                    android:backgroundTint="@color/accent_orange"
                    style="@style/FocusButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Total Screen Time Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_total_screen_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/FocusCardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_screen_time_card"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="📱"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/bg_square_icon"
                    android:backgroundTint="#400A84FF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Social Screen Time"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_total_screen_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 minutes"
                        android:textColor="@color/accent_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Section Dashboard -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REAL-TIME FOCUS REPORT"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Card: Blocked count -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                style="@style/FocusCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚫 Intercepted"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_stat_blocked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_red"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Time Saved -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                style="@style/FocusCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Time Saved"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_stat_saved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textColor="@color/accent_green"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Card: Most Distracting App -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/FocusCardView">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/lbl_most_distracting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Prime Tempter"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <TextView
                    android:id="@+id/txt_most_distracting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None Detected"
                    android:textColor="@color/accent_orange"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Dynamic Breakdown Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/FocusCardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distraction Breakdown"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/btn_reset_stats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reset Stats"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <!-- YouTube Shorts Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎥 YouTube Shorts"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txt_count_youtube"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 blocks"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <ProgressBar
                        android:id="@+id/progress_youtube"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="50"
                        android:progressTint="@color/accent_red"
                        android:progressBackgroundTint="@color/accent_gray" />
                </LinearLayout>

                <!-- Instagram Reels Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📸 Instagram Reels"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txt_count_instagram"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 blocks"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <ProgressBar
                        android:id="@+id/progress_instagram"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="50"
                        android:progressTint="@color/accent_orange"
                        android:progressBackgroundTint="@color/accent_gray" />
                </LinearLayout>

                <!-- TikTok Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵 TikTok"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txt_count_tiktok"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 blocks"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <ProgressBar
                        android:id="@+id/progress_tiktok"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="50"
                        android:progressTint="@color/white"
                        android:progressBackgroundTint="@color/accent_gray" />
                </LinearLayout>

                <!-- Facebook Reels Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥 Facebook Reels"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txt_count_facebook"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 blocks"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <ProgressBar
                        android:id="@+id/progress_facebook"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="50"
                        android:progressTint="@color/accent_blue"
                        android:progressBackgroundTint="@color/accent_gray" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Segment 3: App Blocking Switchboard Controls -->
        <LinearLayout
            android:id="@+id/container_tab_switches"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <!-- Controls / App Blocker List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTECTION SETTINGS"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/FocusCardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Focus Switch Toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/txt_protection_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Global Focus Mode"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activate active Reels/Shorts blocking"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_below="@id/txt_protection_head"
                        android:layout_marginTop="2dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_global_blocker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/card_border" />

                <!-- Strict Mode Toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/txt_strict_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Strict Lockout"
                        android:textColor="@color/accent_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requires Lock PIN to disable protection"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_below="@id/txt_strict_head"
                        android:layout_marginTop="2dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_strict_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/card_border" />

                <!-- TikTok app switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/txt_tiktok_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Block TikTok App"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_block_tiktok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/card_border" />

                <!-- YouTube Shorts switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/txt_yt_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Block YouTube Shorts"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_block_youtube"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/card_border" />

                <!-- Instagram Reels switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/txt_ig_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Block Instagram Reels"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_block_instagram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/card_border" />

                <!-- Facebook Reels switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/txt_fb_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Block Facebook Reels"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_block_facebook"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Segment 4: Security Lockdowns & Administration Safeguards -->
        <LinearLayout
            android:id="@+id/container_tab_security"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <!-- Anti-Uninstall Security -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM &amp; SECURITY"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            style="@style/FocusCardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/admin_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="🛡"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_square_icon"
                        android:backgroundTint="@color/accent_red_glow"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/txt_admin_status_head"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anti-Uninstall Protection"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_toEndOf="@id/admin_icon"
                        android:layout_marginStart="12dp"
                        android:layout_alignTop="@id/admin_icon" />

                    <TextView
                        android:id="@+id/txt_admin_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device Administrator is inactive"
                        android:textColor="@color/accent_red"
                        android:textSize="11sp"
                        android:layout_toEndOf="@id/admin_icon"
                        android:layout_marginStart="12dp"
                        android:layout_below="@id/txt_admin_status_head"
                        android:layout_marginTop="2dp" />
                </RelativeLayout>

                <Button
                    android:id="@+id/btn_toggle_admin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Activate Device Admin"
                    style="@style/FocusButton.Secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

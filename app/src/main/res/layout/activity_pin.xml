<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Screen Cap Icon -->
    <TextView
        android:id="@+id/txt_lock_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="🔒"
        android:textSize="36sp"
        android:gravity="center"
        android:background="@drawable/bg_circle_icon"
        android:backgroundTint="@color/accent_red_glow"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/txt_pin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pin_setup_title"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txt_pin_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pin_desc_strict"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- PIN Visual Indicators (Dots) -->
    <TextView
        android:id="@+id/txt_pin_circles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="_ _ _ _"
        android:textColor="@color/accent_red"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.4"
        android:layout_marginBottom="40dp" />

    <!-- Keyboard Rows of Circular Buttons -->
    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_key_1"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="1"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_2"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="2"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="3"
                style="@style/FocusPinKey" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_key_4"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="4"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_5"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="5"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_6"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="6"
                style="@style/FocusPinKey" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_key_7"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="7"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_8"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="8"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_9"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="9"
                style="@style/FocusPinKey" />
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_key_clear"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="@string/pin_btn_clear"
                android:textColor="@color/accent_red"
                android:textSize="11sp"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_0"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="0"
                android:layout_marginEnd="12dp"
                style="@style/FocusPinKey" />

            <Button
                android:id="@+id/btn_key_submit"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="@string/pin_btn_submit"
                android:textColor="@color/accent_green"
                android:textSize="11sp"
                style="@style/FocusPinKey" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
